# ─── AI 电台配置示例 ───
# cp 到 .env 后填入你自己的值

# Server
PORT=8080

# OpenAI GPT-5.5（必填）
# 如果本机直连 api.openai.com 不稳定，请改成你自己的 OpenAI 兼容代理。
OPENAI_API_URL=https://api.openai.com
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.5
OPENAI_MAX_TOKENS=1024
OPENAI_TIMEOUT_MS=30000
OPENAI_REASONING_EFFORT=low
OPENAI_STREAM=false
OPENAI_WIRE_API=chat

# 网易云音乐登录（可选，带上后 VIP 歌可播）
# 从浏览器 DevTools → Application → Cookies → music.163.com 拿
NCM_MUSIC_U=
NCM_CSRF=
NCM_BITRATE=hires
NCM_BITRATE_FALLBACKS=jyeffect,exhigh,standard
NCM_TOPLIST_TRACK_LIMIT=5
NCM_TIMEOUT_MS=8000

# 网易云 IoT OpenAPI（可选；榜单接口未配置时会退到公开接口）
NCM_OPENAPI_BASE_URL=http://openapi.music.163.com
NCM_OPENAPI_APP_ID=
NCM_OPENAPI_ACCESS_TOKEN=
NCM_OPENAPI_APP_SECRET=
NCM_OPENAPI_PRIVATE_KEY=
NCM_OPENAPI_SIGN_TYPE=RSA_SHA256
NCM_OPENAPI_DEVICE_JSON={"channel":"box","deviceId":"ai-radio-station","deviceType":"soundbox","appVer":"1.0.0","os":"soundbox","osVer":"1.0.0","brand":"box","model":"soundbox"}

# TTS（可选）
TTS_PROVIDER=auto
TTS_MAX_INPUT_BYTES=2048

# Fish Audio TTS
FISH_API_KEY=
FISH_VOICE_ID=
FISH_FORMAT=mp3
FISH_LATENCY=normal
FISH_TIMEOUT_MS=15000

# 有道智云 TTS
YOUDAO_TTS_API_URL=https://openapi.youdao.com/ttsapi
YOUDAO_TTS_APP_KEY=
YOUDAO_TTS_APP_SECRET=
YOUDAO_TTS_VOICE_NAME=youxiaoxun
YOUDAO_TTS_SPEED=1.2
YOUDAO_TTS_VOLUME=2.00

# DJ 串场（可选）
DJ_ENABLED=true
DJ_MAX_CHARS=160
DJ_GAP_MIN=1
DJ_GAP_MAX=1

# 天气（可选，用于给 AI 提供天气上下文）
WEATHER_PROVIDER=caiyun
WEATHER_CITY=合肥
WEATHER_LONGITUDE=117.2272
WEATHER_LATITUDE=31.8206
WEATHER_TIMEOUT_MS=5000
CAIYUN_APP_KEY=
CAIYUN_APP_SECRET=
CAIYUN_TOKEN=
OPENWEATHER_KEY=

# 联网搜索（可选，用于最新榜单/当前歌曲背景）
WEB_SEARCH_PROVIDER=zhipu
WEB_SEARCH_API_KEY=
WEB_SEARCH_ENGINE=search_std
WEB_SEARCH_COUNT=5
WEB_SEARCH_RECENCY_FILTER=noLimit
WEB_SEARCH_CONTENT_SIZE=medium
WEB_SEARCH_TIMEOUT_MS=15000
WEB_SEARCH_USER_ID=ai-radio-station

# 状态持久化
STATE_FILE=state.json
STATE_MAX_PLAYS=500
STATE_MAX_MESSAGES=50

# 队列
QUEUE_SEARCH_LIMIT=1
DIRECT_SEARCH_LIMIT=3

# 调度器
SCHEDULER_ENABLED=true
SCHEDULER_HOURLY=false
